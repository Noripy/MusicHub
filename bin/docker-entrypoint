#!/bin/bash -e

# MusicHub 本番エントリポイント（Render 無料枠版）
#
# 方針:
#   Pre-Deploy Command は有料プラン専用のため使えない。
#   代わりに、サーバ起動時にここで db:prepare を実行する。
#   無料枠は単一インスタンスなので、複数インスタンスが同時に
#   マイグレーションする競合は起こらず、これで安全。

# jemalloc を有効化（メモリ断片化を抑え、Render の限られた RAM で安定）
if [ -z "${LD_PRELOAD+x}" ]; then
  LD_PRELOAD=$(find / -name "libjemalloc.so.2" -print -quit 2>/dev/null || true)
  export LD_PRELOAD
fi

# サーバ起動コマンドのときだけ DB を準備（console 等では走らせない）
# Pattern C のため、Neon に primary + Solid(cache/queue/cable) テーブルを作る
if [[ "$*" == *"server"* ]]; then
  ./bin/rails db:prepare

  # cache/queue/cable は primary と同じ物理DB（Neon無料枠は1DBのみ）を共有しており、
  # db:prepare は「DBは既に存在する」と判断して各roleのテーブル作成をスキップしてしまう。
  # 該当テーブルが無いときだけ、それぞれのschemaを明示的にロードする。
  DISABLE_DATABASE_ENVIRONMENT_CHECK=1 ./bin/rails runner '
    { cache: "solid_cache_entries", queue: "solid_queue_jobs", cable: "solid_cable_messages" }.each do |role, table|
      next if ActiveRecord::Base.connection.table_exists?(table)

      Rails.logger.info("[docker-entrypoint] #{table} が無いため db:schema:load:#{role} を実行します")
      system({ "DISABLE_DATABASE_ENVIRONMENT_CHECK" => "1" }, "./bin/rails", "db:schema:load:#{role}", exception: true)
    end
  '
fi

exec "${@}"
