# MusicHub 環境変数サンプル（コピーして .env を作る。.env はコミットしない）

# --- ローカル開発（compose が自動で読み込む） -----------------------
# compose.yaml 側で既定値を入れているので通常は未設定でOK。
# 上書きしたい場合のみ記述する。
# DATABASE_URL=postgres://postgres:password@db:5432/musichub_development

# --- 本番（Render の Environment に設定する。リポジトリには置かない） ---
# RAILS_MASTER_KEY=        # config/master.key の中身
# DATABASE_URL=            # Neon の direct connection string
# RAILS_LOG_TO_STDOUT=true
# RAILS_SERVE_STATIC_FILES=true   # Thruster/Propshaftで静的配信する場合
