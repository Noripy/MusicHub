#!/bin/bash -e

# MusicHub 本番エントリポイント
#
# 方針: マイグレーションはここで実行しない。
#       Render の "Pre-Deploy Command" に `bin/rails db:migrate` を設定し、
#       スケール時に複数インスタンスが同時に migrate する競合を避ける。

# jemalloc を有効化（メモリ断片化を抑え、Renderの限られたRAMで安定）
if [ -z "${LD_PRELOAD+x}" ]; then
  LD_PRELOAD=$(find / -name "libjemalloc.so.2" -print -quit 2>/dev/null || true)
  export LD_PRELOAD
fi

exec "${@}"
