<% content_for :title, "ログイン — MusicHub" %>

<div class="mh-subhead">
  <%= link_to root_path, class: "mh-subhead-back" do %>←<% end %>
  <span class="mh-subhead-title">ログイン</span>
</div>

<p class="text-[13px] text-text-secondary">メールアドレスとパスワードでログインします。</p>

<%= form_with url: session_url, class: "contents" do |form| %>
  <div class="flex flex-col gap-4">
    <div class="mh-field">
      <%= form.label :email_address, "メールアドレス", class: "mh-label" %>
      <%= form.email_field :email_address,
            class: "mh-input",
            required: true,
            autofocus: true,
            autocomplete: "username",
            placeholder: "you@example.com",
            value: params[:email_address] %>
    </div>

    <div class="mh-field">
      <%= form.label :password, "パスワード", class: "mh-label" %>
      <%= form.password_field :password,
            class: "mh-input",
            required: true,
            autocomplete: "current-password",
            placeholder: "パスワードを入力",
            maxlength: 72 %>
    </div>

    <div class="h-2"></div>

    <%= form.submit "ログイン", class: "mh-btn-primary cursor-pointer" %>
  </div>
<% end %>

<div class="flex flex-col gap-2">
  <%= link_to "パスワードをお忘れの方はこちら →", new_password_path, class: "mh-link" %>
  <%= link_to "アカウントをお持ちでない方はこちら →", new_registration_path, class: "mh-link" %>
</div>
