<%# ② サインアップ（Figma node 1:14） %>
<% content_for :title, "アカウント作成 — MusicHub" %>

<div class="mh-subhead">
  <%= link_to root_path, class: "mh-subhead-back" do %>←<% end %>
  <span class="mh-subhead-title">アカウント作成</span>
</div>

<p class="text-[13px] text-text-secondary">メールアドレスとパスワードで登録します。</p>

<% if @user&.errors&.any? %>
  <div class="rounded-[10px] border border-state-unset bg-state-unset-bg px-4 py-3">
    <ul class="space-y-1 text-[13px] text-state-unset">
      <% @user.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with url: registration_path, method: :post do |f| %>
  <div class="flex flex-col gap-4">
    <div class="mh-field">
      <%= f.label :name, "ユーザー名（任意）", class: "mh-label" %>
      <%= f.text_field :name,
            name: "user[name]",
            class: "mh-input",
            placeholder: "例: のりぴー",
            autocomplete: "nickname" %>
    </div>

    <div class="mh-field">
      <%= f.label :email_address, "メールアドレス", class: "mh-label" %>
      <%= f.email_field :email_address,
            name: "user[email_address]",
            class: "mh-input",
            placeholder: "you@example.com",
            autocomplete: "email",
            required: true %>
    </div>

    <div class="mh-field">
      <%= f.label :password, "パスワード", class: "mh-label" %>
      <%= f.password_field :password,
            name: "user[password]",
            class: "mh-input",
            placeholder: "8文字以上",
            autocomplete: "new-password",
            required: true %>
    </div>

    <div class="mh-field">
      <%= f.label :password_confirmation, "パスワード（確認）", class: "mh-label" %>
      <%= f.password_field :password_confirmation,
            name: "user[password_confirmation]",
            class: "mh-input",
            placeholder: "もう一度入力",
            autocomplete: "new-password",
            required: true %>
    </div>

    <div class="h-2"></div>

    <%= f.submit "登録する", class: "mh-btn-primary cursor-pointer" %>
  </div>
<% end %>

<%= link_to "すでにアカウントをお持ちの方はこちら →", new_session_path, class: "mh-link" %>
