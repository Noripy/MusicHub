<%# ⑤ ホーム / イベント一覧 %>
<% content_for :title, "ホーム — MusicHub" %>

<div class="flex items-center justify-between">
  <h1 class="text-[18px] font-bold text-accent">MusicHub</h1>
</div>

<%= link_to new_event_path, class: "mh-btn-primary" do %>
  ＋ イベントを記録する
<% end %>

<% if @events.any? %>
  <p class="text-[13px] font-semibold text-text-secondary">あなたのイベント（新しい順）</p>

  <% @events.each do |event| %>
    <%= link_to event_path(event), class: "mh-card relative block" do %>
      <div class="flex items-center justify-between">
        <span class="text-[15px] font-semibold text-text-primary"><%= event.name %></span>
      </div>

      <% if event.held_on.present? || event.venue.present? %>
        <p class="text-[13px] text-text-secondary">
          <%= [event.held_on&.strftime("%Y/%m/%d %H:%M"), event.venue].compact.join("  ·  ") %>
        </p>
      <% end %>

      <% if event.dj_name.present? %>
        <p class="text-[13px] text-text-secondary">DJ: <%= event.dj_name %></p>
      <% end %>
    <% end %>
  <% end %>

  <div class="h-1"></div>
  <%= link_to track_entries_path, class: "text-[13px] font-medium text-accent" do %>
    🔎 未識別の曲を見る →
  <% end %>

<% else %>
  <div class="flex flex-1 flex-col items-center justify-center gap-3 py-16 text-center">
    <p class="text-[15px] font-semibold text-text-primary">イベントがまだありません</p>
    <p class="text-[13px] text-text-muted">「＋ イベントを記録する」から<br>最初のイベントを追加しましょう</p>
  </div>
<% end %>
