<% content_for :title, "新しいパスワードの設定 — MusicHub" %>

<div class="mh-subhead">
  <%= link_to new_session_path, class: "mh-subhead-back" do %>←<% end %>
  <span class="mh-subhead-title">新しいパスワードの設定</span>
</div>

<%= form_with url: password_path(params[:token]), method: :put, class: "contents" do |form| %>
  <div class="flex flex-col gap-4">
    <div class="mh-field">
      <%= form.label :password, "新しいパスワード", class: "mh-label" %>
      <%= form.password_field :password,
            class: "mh-input",
            required: true,
            autocomplete: "new-password",
            placeholder: "8文字以上",
            maxlength: 72 %>
    </div>

    <div class="mh-field">
      <%= form.label :password_confirmation, "新しいパスワード（確認）", class: "mh-label" %>
      <%= form.password_field :password_confirmation,
            class: "mh-input",
            required: true,
            autocomplete: "new-password",
            placeholder: "もう一度入力",
            maxlength: 72 %>
    </div>

    <div class="h-2"></div>

    <%= form.submit "パスワードを更新する", class: "mh-btn-primary cursor-pointer" %>
  </div>
<% end %>
