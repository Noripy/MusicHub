<% content_for :title, "パスワード再設定 — MusicHub" %>

<div class="mh-subhead">
  <%= link_to new_session_path, class: "mh-subhead-back" do %>←<% end %>
  <span class="mh-subhead-title">パスワード再設定</span>
</div>

<p class="text-[13px] text-text-secondary">登録済みのメールアドレスに再設定用のリンクを送信します。</p>

<%= form_with url: passwords_path, class: "contents" do |form| %>
  <div class="flex flex-col gap-4">
    <div class="mh-field">
      <%= form.label :email_address, "メールアドレス", class: "mh-label" %>
      <%= form.email_field :email_address,
            class: "mh-input",
            required: true,
            autofocus: true,
            autocomplete: "username",
            placeholder: "you@example.com",
            value: params[:email_address] %>
    </div>

    <div class="h-2"></div>

    <%= form.submit "再設定メールを送信する", class: "mh-btn-primary cursor-pointer" %>
  </div>
<% end %>

<%= link_to "ログイン画面に戻る →", new_session_path, class: "mh-link" %>
